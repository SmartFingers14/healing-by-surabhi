# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

.vercel
.env*.local

# graphify knowledge graph
# The graph (graph.json / graph.html / GRAPH_REPORT.md) is committed so the
# whole team shares one map. Only the local-only cache & cost files are ignored.
graphify-out/cache/
graphify-out/cost.json
graphify-out/.graphify_python

